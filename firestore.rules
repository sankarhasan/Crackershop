rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products collection: public read/write (development mode)
    match /products/{productId} {
      allow read, write: if true;
    }

    // Categories collection: public read/write (development mode)
    match /categories/{categoryId} {
      allow read, write: if true;
    }

    // Enquiries collection: public read/write (development mode)
    match /enquiries/{enquiryId} {
      allow read, write: if true;
    }

    // Banners collection: public read/write (development mode)
    match /banners/{bannerId} {
      allow read, write: if true;
    }

    // Offers collection: public read/write (development mode)
    match /offers/{offerId} {
      allow read, write: if true;
    }

    // Coupons collection: public read/write (development mode)
    match /coupons/{couponId} {
      allow read, write: if true;
    }

    // State Rules collection: public read for frontend, write for admin
    match /stateRules/{stateRuleId} {
      allow read, write: if true;
    }
  }
}
